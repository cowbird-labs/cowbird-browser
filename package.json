{
  "name": "cowbird-extension",
  "version": "0.9.0",
  "private": true,
  "type": "module",
  "description": "Browser-extension client for the cowbird password manager (Vault-backed, end-to-end encrypted).",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "libsodium-wrappers-sumo": "^0.7.15",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "totp-generator": "^2.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/libsodium-wrappers-sumo": "^0.7.8",
    "@types/node": "^22.10.0",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.2",
    "@wxt-dev/module-react": "^1.2.2",
    "typescript": "^5.7.0",
    "vitest": "^3.2.6",
    "wxt": "^0.20.26"
  }
}
