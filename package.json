{
  "name": "cowbird-extension",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "description": "Browser-extension client for the cowbird password manager (Vault-backed, end-to-end encrypted).",
  "license": "GPL-3.0-or-later",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "postinstall": "wxt prepare",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "fflate": "^0.8.3",
    "hash-wasm": "^4.12.0",
    "libsodium-wrappers-sumo": "^0.8.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "totp-generator": "^2.0.1",
    "webextension-polyfill": "^0.12.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/webextension-polyfill": "^0.12.5",
    "@vitejs/plugin-react": "^6.0.3",
    "@wxt-dev/module-react": "^1.2.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9",
    "wxt": "^0.20.27"
  },
  "overrides": {
    "shell-quote": "^1.8.4",
    "tmp": "^0.2.6",
    "uuid": "^11.1.1",
    "esbuild": "^0.28.1"
  }
}
